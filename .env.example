# Required for LLM features (naive LLM mode and RAG mode)
GEMINI_API_KEY=your_api_key_here

# Optional: URLs for External RAG mode (comma or newline separated)
EXTERNAL_DOC_URLS=

# Optional: minimum groundedness score (0.0 to 1.0) before answer is allowed
VALIDATION_MIN_SCORE=0.65

# Optional: JSONL log path for validated External RAG runs
DOCUBOT_LOG_PATH=logs/external_rag_runs.jsonl